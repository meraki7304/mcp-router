{
  "name": "mcp-router",
  "version": "1.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-router/mcp-router"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "turbo run dev --filter=@mcp_router/shared --filter=@mcp_router/ui --filter=@mcp_router/electron",
    "build": "turbo run build",
    "publish": "turbo run publish --filter=@mcp_router/electron",
    "make": "turbo run make",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs --fix",
    "typecheck": "turbo run typecheck",
    "knip": "knip",
    "test:e2e": "pnpm --filter @mcp_router/electron run test:e2e",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "knip": "^6.7.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@octokit/request-error@>=1.0.0 <5.1.1": ">=5.1.1",
      "@octokit/request@>=1.0.0 <8.4.1": ">=8.4.1",
      "@octokit/plugin-paginate-rest@>=1.0.0 <9.2.2": ">=9.2.2",
      "on-headers@<1.1.0": ">=1.1.0",
      "qs@<6.14.1": ">=6.14.1",
      "@eslint/plugin-kit@<0.3.3": ">=0.3.3",
      "jsondiffpatch@<0.7.2": ">=0.7.2",
      "tmp@<=0.2.3": ">=0.2.4",
      "@modelcontextprotocol/sdk@<1.29.0": ">=1.29.0",
      "react-router@>=7.0.0 <=7.11.0": ">=7.12.0",
      "react-router@>=7.0.0 <7.12.0": ">=7.12.0",
      "preact@>=10.28.0 <10.28.2": ">=10.28.2"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "core-js",
      "electron",
      "esbuild"
    ]
  }
}
