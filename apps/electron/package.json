{
  "name": "@mcp_router/electron",
  "productName": "MCP Router",
  "version": "1.0.0",
  "private": true,
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/meraki7304/mcp-router.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "pack": "electron-vite build && electron-builder --dir",
    "make": "electron-vite build && electron-builder",
    "make:x64": "cross-env npm_config_target_arch=x64 electron-vite build && electron-builder --x64",
    "make:arm64": "cross-env npm_config_target_arch=arm64 electron-vite build && electron-builder --arm64",
    "publish": "electron-vite build && electron-builder --publish always",
    "lint": "eslint --ext .ts,.tsx .",
    "lint:fix": "eslint --ext .ts,.tsx . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "cd ../.. && knip --workspace apps/electron",
    "rebuild": "electron-rebuild",
    "rebuild:x64": "cross-env npm_config_target_arch=x64 npm_config_arch=x64 electron-rebuild --arch=x64",
    "rebuild:arm64": "cross-env npm_config_target_arch=arm64 npm_config_arch=arm64 electron-rebuild --arch=arm64",
    "test:e2e": "pnpm make && playwright test --config=e2e/playwright-electron.config.ts",
    "test:e2e:only": "playwright test --config=e2e/playwright-electron.config.ts",
    "test:e2e:headed": "pnpm make && playwright test --config=e2e/playwright-electron.config.ts --headed"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@mcp_router/shared": "workspace:*",
    "@mcp_router/tailwind-config": "workspace:*",
    "@mcp_router/ui": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tabler/icons-react": "^3.41.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "better-sqlite3": "^12.9.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "electron-updater": "^6.8.3",
    "execa": "^9.6.1",
    "express": "^5.2.1",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "immer": "^11.1.4",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.2",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "strip-ansi": "^7.2.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.2.0",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
